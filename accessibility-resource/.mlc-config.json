{
  "ignorePatterns": [
    { "pattern": "^https://github\\.com/alexarguello/accessibility-hub/edit" },
    { "pattern": "^mailto:" },
    { "pattern": "^#" },
    { "pattern": "[\"']|%22|%27|%5B|%5D" }
  ],
  "replacementPatterns": [
    {
      "pattern": "^/accessibility-hub/",
      "replacement": "https://alexarguello.github.io/accessibility-hub/"
    },
    {
      "pattern": "^/docs/",
      "replacement": "https://alexarguello.github.io/accessibility-hub/docs/"
    }
  ],
  "retryOn429": true,
  "retryCount": 2,
  "fallbackRetryDelay": "30s",
  "timeout": "20s",
  "aliveStatusCodes": [200, 206, 403, 405]
}
