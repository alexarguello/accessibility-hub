{
  "ignorePatterns": [
    { "pattern": "^https://github\\.com/alexarguello/accessibility-hub/edit" },
    { "pattern": "^mailto:" },
    { "pattern": "^#" }
  ],
  "replacementPatterns": [
    {
      "pattern": "^/accessibility-hub/",
      "replacement": "https://alexarguello.github.io/accessibility-hub/"
